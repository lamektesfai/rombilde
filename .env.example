# Miljøvariabler for Rombilde
# Se CLAUDE.md for hvor du oppretter disse kontoene.

# Postgres (Supabase eller Neon)
DATABASE_URL="postgresql://user:password@localhost:5432/rombilde?schema=public"

# Cloudflare R2 (S3-kompatibel bildelagring)
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""

# AI virtual staging API (Decor8 AI eller tilsvarende)
AI_STAGING_API_KEY=""

# Vipps ePayment API
VIPPS_CLIENT_ID=""
VIPPS_CLIENT_SECRET=""
VIPPS_SUBSCRIPTION_KEY=""
VIPPS_MERCHANT_SERIAL_NUMBER=""
VIPPS_WEBHOOK_SECRET=""
VIPPS_BASE_URL="https://apitest.vipps.no"

# Resend (transaksjonell e-post)
RESEND_API_KEY=""
# Valgfri: bytt til f.eks. "Rombilde <no-reply@rombilde.no>" når domenet er verifisert i Resend.
RESEND_FROM_EMAIL="Rombilde <onboarding@resend.dev>"

# App
APP_BASE_URL="http://localhost:3000"

# Inngest (bakgrunnskø for AI-prosessering)
# INNGEST_DEV er kun for lokal utvikling — fjern/ikke sett denne i produksjon (Vercel),
# der EVENT_KEY/SIGNING_KEY under brukes i stedet.
INNGEST_DEV="http://localhost:8288"
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
